@startuml ServicePath - Simple Architecture
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 14
title ServicePath Platform - How It Works
package "What You See & Use" as Frontend #E3F2FD {
  
  rectangle "Account & Login" as Auth {
    [Create Account] as Register
    [Sign In] as Login
    [Account Info & Settings] as AccountInfo
  }
  
  rectangle "Finding Opportunities" as Discovery {
    [Personality Quiz] as Quiz
    [Browse Opportunities] as Browse
    [Search & Filter] as Search
  }
  
  rectangle "Tracking Your Service" as Tracking {
    [Log Volunteer Hours] as LogHours
    [Write Reflections] as Reflections
    [View Your Stats] as Stats
  }
  
  rectangle "Sharing Your Impact" as Sharing {
    [Generate Summary] as Summary
    [Share Link] as ShareLink
  }
}
package "Behind the Scenes" as Backend #FFF9C4 {
  
  rectangle "Security & Authentication" as Security {
    [Password Protection] as Passwords
    [Session Management] as Sessions
  }
  
  rectangle "Data Management" as DataMgmt {
    [Your Profile] as Profile
    [Your Hours & Activities] as Hours
    [Your Reflections] as UserReflections
    [Shareable Links] as Links
  }
  
  rectangle "Smart Matching" as Matching {
    [Quiz Results Analysis] as QuizAnalysis
    [Opportunity Filtering] as Filter
  }
}
database "Opportunity Database" as OppDB #FFCCBC {
  file "20 Volunteer\nOpportunities\n(8 Categories)" as CSV
}
cloud "Optional AI\nRecommendations" as AI #E1BEE7
' User interactions
Register --> Passwords : "creates account with\nencrypted password"
Login --> Sessions : "logs you in securely"
AccountInfo --> Profile : "shows your stats\n& allows deletion"
Quiz --> QuizAnalysis : "analyzes your\ninterests & goals"
Browse --> Filter : "shows matching\nopportunities"
Search --> Filter : "finds specific\nopportunities"
LogHours --> Hours : "saves your\nvolunteer time"
Reflections --> UserReflections : "stores your thoughts"
Stats --> Hours : "calculates total hours\n& account age"
Summary --> Links : "creates shareable\nsummary"
ShareLink --> Links : "generates public link"
' Backend connections
QuizAnalysis --> Filter : "determines\nwhat to show you"
Filter --> OppDB : "pulls relevant\nopportunities"
Passwords --> Profile : "protects your data"
Sessions --> Profile : "keeps you logged in"
' External data
CSV --> OppDB : "provides volunteer\nopportunity list"
AI -.> Filter : "can suggest matches\n(currently disabled\nfor speed)"
note right of Frontend
  <b>Your Experience</b>
  Everything you click,
  view, and interact with
end note
note right of Backend
  <b>System Processing</b>
  Handles your data securely,
  filters opportunities,
  calculates statistics
end note
note bottom of OppDB
  Pre-loaded opportunities
  across 8 categories:
  • Environment & Nature
  • Education & Training
  • Animal Welfare
  • Arts & Culture
  • Technology & STEM
  • Community Service
  • Senior Care
  • Youth Mentoring
end note
@enduml